---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<BaseLayout title="博客">
  <section class="blog-header">
    <h1>
      <span class="gradient-text">博客</span>
    </h1>
    <p class="subtitle">写下我对技术、设计和生活的思考与探索。</p>
  </section>

  <div class="search-wrapper">
    <div class="search-box">
      <svg class="search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="11" cy="11" r="8"/>
        <path d="m21 21-4.35-4.35"/>
      </svg>
      <input type="text" id="searchInput" class="search-input" placeholder="搜索文章标题、描述或标签..." autocomplete="off" />
      <kbd class="search-shortcut">ESC</kbd>
    </div>
  </div>

  <div class="posts-list" id="postsList">
    {posts.map((post, i) => (
      <a
        href={`${import.meta.env.BASE_URL}/blog/${post.slug}/`}
        class="post-item"
        style={`animation-delay: ${i * 0.05}s`}
        data-title={post.data.title.toLowerCase()}
        data-desc={post.data.description.toLowerCase()}
        data-tags={post.data.tags?.join(' ').toLowerCase() || ''}
      >
        <div class="post-left">
          <time datetime={post.data.pubDate.toISOString()}>
            {post.data.pubDate.toLocaleString('zh-CN', { year: 'numeric', month: '2-digit', day: '2-digit', hour: '2-digit', minute: '2-digit' })}
          </time>
        </div>
        <div class="post-center">
          <h2>{post.data.title}</h2>
          <p>{post.data.description}</p>
        </div>
        <div class="post-right">
          {post.data.tags?.length > 0 && (
            <div class="tags">
              {post.data.tags.map((tag) => (
                <span class="tag">{tag}</span>
              ))}
            </div>
          )}
          <span class="arrow">→</span>
        </div>
      </a>
    ))}
  </div>

  <div class="empty-state" id="emptyState" style="display: none;">
    <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="11" cy="11" r="8"/>
      <path d="m21 21-4.35-4.35"/>
      <path d="M8 11h6"/>
    </svg>
    <p>没有找到匹配的文章</p>
    <span>试试其他关键词？</span>
  </div>
</BaseLayout>

<script>
  function initSearch() {
    const input = document.getElementById('searchInput') as HTMLInputElement;
    const postsList = document.getElementById('postsList');
    const emptyState = document.getElementById('emptyState');
    if (!input || !postsList || !emptyState) return;

    const items = postsList.querySelectorAll('.post-item');

    input.addEventListener('input', () => {
      const query = input.value.toLowerCase().trim();
      let visibleCount = 0;

      items.forEach((item) => {
        const el = item as HTMLElement;
        const title = el.dataset.title || '';
        const desc = el.dataset.desc || '';
        const tags = el.dataset.tags || '';
        const match = !query || title.includes(query) || desc.includes(query) || tags.includes(query);

        el.style.display = match ? '' : 'none';
        if (match) visibleCount++;
      });

      emptyState.style.display = visibleCount === 0 ? '' : 'none';
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === '/' && document.activeElement !== input) {
        e.preventDefault();
        input.focus();
      }
      if (e.key === 'Escape') {
        input.value = '';
        input.dispatchEvent(new Event('input'));
        input.blur();
      }
    });
  }

  document.addEventListener('DOMContentLoaded', initSearch);
</script>

<style>
  .blog-header {
    padding: 4rem 0 3rem;
  }

  .blog-header h1 {
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    margin-bottom: 1rem;
    animation: fadeInUp 0.5s ease backwards;
  }

  .gradient-text {
    background: var(--accent-gradient);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .subtitle {
    color: var(--text-secondary);
    font-size: 1.1rem;
    animation: fadeInUp 0.5s ease 0.1s backwards;
  }

  .search-wrapper {
    margin-bottom: 2rem;
    animation: fadeInUp 0.5s ease 0.15s backwards;
  }

  .search-box {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    background: rgba(255, 255, 255, 0.8);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 0 1rem;
    transition: all 0.3s ease;
    backdrop-filter: blur(10px);
  }

  .search-box:focus-within {
    border-color: var(--accent);
    box-shadow: 0 0 0 3px rgba(108, 92, 231, 0.1);
    background: #fff;
  }

  .search-icon {
    color: var(--text-muted);
    flex-shrink: 0;
    transition: color 0.3s;
  }

  .search-box:focus-within .search-icon {
    color: var(--accent);
  }

  .search-input {
    flex: 1;
    border: none;
    background: none;
    padding: 0.875rem 0;
    font-size: 0.95rem;
    color: var(--text);
    outline: none;
    font-family: inherit;
  }

  .search-input::placeholder {
    color: var(--text-muted);
  }

  .search-shortcut {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.2rem 0.5rem;
    border-radius: 6px;
    background: var(--bg);
    border: 1px solid var(--border);
    color: var(--text-muted);
    font-size: 0.7rem;
    font-family: inherit;
    font-weight: 500;
    flex-shrink: 0;
    transition: all 0.2s;
  }

  .search-box:focus-within .search-shortcut {
    opacity: 0;
    width: 0;
    padding: 0;
    margin: 0;
    overflow: hidden;
  }

  .posts-list {
    display: flex;
    flex-direction: column;
  }

  .post-item {
    display: grid;
    grid-template-columns: 120px 1fr auto;
    align-items: center;
    gap: 2rem;
    padding: 1.5rem 0;
    border-bottom: 1px solid var(--border);
    text-decoration: none;
    color: inherit;
    transition: all 0.2s ease;
    animation: fadeInUp 0.4s ease backwards;
  }

  .post-item:first-child {
    border-top: 1px solid var(--border);
  }

  .post-item:hover {
    padding-left: 1rem;
    border-color: var(--border-hover);
  }

  .post-left time {
    color: var(--text-muted);
    font-size: 0.85rem;
    font-weight: 500;
    font-variant-numeric: tabular-nums;
  }

  .post-center h2 {
    font-size: 1.15rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    margin-bottom: 0.3rem;
    transition: color 0.2s;
  }

  .post-item:hover .post-center h2 {
    color: var(--accent-2);
  }

  .post-center p {
    color: var(--text-secondary);
    font-size: 0.9rem;
    line-height: 1.6;
  }

  .post-right {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .tags {
    display: flex;
    gap: 0.4rem;
  }

  .tag {
    padding: 0.2rem 0.6rem;
    border-radius: 6px;
    background: rgba(108, 92, 231, 0.12);
    color: var(--accent-2);
    font-size: 0.7rem;
    font-weight: 500;
    white-space: nowrap;
  }

  .arrow {
    color: var(--text-muted);
    font-size: 1.2rem;
    transition: all 0.3s ease;
  }

  .post-item:hover .arrow {
    color: var(--accent-2);
    transform: translateX(4px);
  }

  .empty-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 4rem 2rem;
    color: var(--text-muted);
    text-align: center;
    gap: 0.75rem;
    animation: fadeInUp 0.3s ease;
  }

  .empty-state svg {
    opacity: 0.4;
    margin-bottom: 0.5rem;
  }

  .empty-state p {
    font-size: 1.05rem;
    font-weight: 500;
    color: var(--text-secondary);
  }

  .empty-state span {
    font-size: 0.85rem;
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(15px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 768px) {
    .post-item {
      grid-template-columns: 1fr;
      gap: 0.5rem;
      padding: 1.25rem 0;
    }

    .post-left {
      order: -1;
    }

    .post-right {
      justify-content: flex-start;
    }

    .arrow {
      display: none;
    }

    .search-shortcut {
      display: none;
    }
  }
</style>
